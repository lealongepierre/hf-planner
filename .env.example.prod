# PostgreSQL
POSTGRES_USER=hfplanner
POSTGRES_PASSWORD=<SECURE_PASSWORD>
POSTGRES_DB=hfplanner

# Backend
DATABASE_URL=postgresql://hfplanner:<SECURE_PASSWORD>@postgres:5432/hfplanner
JWT_SECRET_KEY=<generate with: openssl rand -hex 32>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Access code for signup (leave empty for open signup)
SIGNUP_ACCESS_CODE=
